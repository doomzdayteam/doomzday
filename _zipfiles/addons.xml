<addons>
<addon id="plugin.video.thearchives" name="The Archives" version="1.2.0.9" provider-name="The Archivist's">
  <requires>
    <import addon="xbmc.python" version="3.0.0" />
    <import addon="script.module.requests" />
    <import addon="script.module.beautifulsoup4" />
    <import addon="script.module.routing"/>
    <import addon="script.module.six" />
    <import addon="script.module.unidecode" />
    <import addon="script.module.inputstreamhelper" />
    <import addon="inputstream.adaptive" />
	<import addon="inputstream.ffmpegdirect" />

  </requires>
  <extension point="xbmc.python.pluginsource" library="default.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en_GB">Collections</summary>
    <platform>all</platform>
    <language>en</language>
    <license>GPL-2.0-or-later</license>
	<assets>
		<icon>icon.png</icon>
		<fanart>fanart.jpg</fanart>
  </assets>
  </extension>
</addon>

