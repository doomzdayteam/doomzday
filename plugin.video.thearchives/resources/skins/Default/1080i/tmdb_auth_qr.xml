<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog">
    <coordinates>
        <system>1</system>
    </coordinates>
    <controls>
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="DD000000">archives_common/white.png</texture>
        </control>
        <control type="image">
            <left>300</left>
            <top>120</top>
            <width>1320</width>
            <height>840</height>
            <texture colordiffuse="EE111111" border="30">archives_common/circle.png</texture>
        </control>
        <control type="label">
            <left>380</left>
            <top>175</top>
            <width>1160</width>
            <height>60</height>
            <font>font14</font>
            <textcolor>FFFFFFFF</textcolor>
            <label>$INFO[Window.Property(tmdb.title)]</label>
        </control>
        <control type="image">
            <left>350</left>
            <top>235</top>
            <width>610</width>
            <height>610</height>
            <aspectratio>keep</aspectratio>
            <texture background="true">$INFO[Window.Property(tmdb.qr_url)]</texture>
        </control>
        <control type="label">
            <left>980</left>
            <top>285</top>
            <width>500</width>
            <height>48</height>
            <font>font13</font>
            <textcolor>FFFFFFFF</textcolor>
            <label>Scan the QR code with your phone</label>
        </control>
        <control type="textbox">
            <left>980</left>
            <top>350</top>
            <width>520</width>
            <height>130</height>
            <font>font12</font>
            <textcolor>FFDDDDDD</textcolor>
            <label>Approve access on TMDb, then leave this screen open while Kodi finishes authorization.</label>
        </control>
        <control type="label">
            <left>980</left>
            <top>510</top>
            <width>520</width>
            <height>50</height>
            <font>font12</font>
            <textcolor>FFAAAAAA</textcolor>
            <label>Fallback URL</label>
        </control>
        <control type="textbox">
            <left>980</left>
            <top>570</top>
            <width>520</width>
            <height>190</height>
            <font>font10</font>
            <textcolor>FFAAAAAA</textcolor>
            <label>$INFO[Window.Property(tmdb.auth_url)]</label>
        </control>
        <control type="label">
            <left>980</left>
            <top>800</top>
            <width>520</width>
            <height>36</height>
            <font>font10</font>
            <textcolor>FFAAAAAA</textcolor>
            <label>Back/Cancel closes this screen.</label>
        </control>
    </controls>
</window>
